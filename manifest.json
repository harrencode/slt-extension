{
  "manifest_version": 3,
  "name": "SLT Data Monitor",
  "version": "1.0",
  "description": "Monitor your SLT broadband usage and get notified when data is low.",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://myslt.slt.lk/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/brand16.png",
      "48": "icons/brand48.png",
      "128": "icons/brand128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://myslt.slt.lk/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/brand16.png",
    "48": "icons/brand48.png",
    "128": "icons/brand128.png"
  }
}
